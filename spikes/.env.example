# Copy to .env (gitignored) and fill in.

# OpenRouter — primary LLM inference for the agent runtime (Week 2+).
# Sign up: https://openrouter.ai/. Free tier covers Day-2 scaffolding.
OPENROUTER_API_KEY=

# Groq — fast-path inference fallback (used for sub-agent batched calls
# where latency matters; OpenRouter remains primary). Optional.
GROQ_API_KEY=

# Venice API — spikes 1, 2, 3, and the demo's x402 inference path
VENICE_API_KEY=

# Venice Crypto-RPC base URL (verify in docs; spike 1/2 will hit this)
VENICE_RPC_BASE=https://api.venice.ai/api/v1/crypto/rpc

# Funded Base Sepolia test wallet — spikes 1, 4, 8
BASE_SEPOLIA_PK=

# Public Base Sepolia endpoints — fallback / observation
BASE_SEPOLIA_HTTP=https://base-sepolia.publicnode.com
BASE_SEPOLIA_WS=wss://base-sepolia.publicnode.com

# Tenderly Web3 Actions — spike 4 (free alternative to Alchemy Notify)
TENDERLY_ACCESS_KEY=
TENDERLY_ACCOUNT_SLUG=
TENDERLY_PROJECT_SLUG=

# webhook.site receiver — spike 4
WEBHOOK_RECEIVER_URL=
